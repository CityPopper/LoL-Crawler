# ── Security ──────────────────────────────────────────────────────────────────
# IMPORTANT: In production, restrict this file's permissions:
#   chmod 600 .env
#   chown <service-user>:<service-group> .env
# This prevents other users on the host from reading secrets (RIOT_API_KEY,
# REDIS_PASSWORD) stored in this file.

# ── Container runtime ─────────────────────────────────────────────────────────
# Default runtime is podman. Override per-command: RUNTIME=docker just build
# Or set here to always use docker:
# RUNTIME=docker

# Compose project name — controls the Docker/Podman network name used by
# `just seed` and `just admin` (default: directory name).
# COMPOSE_PROJECT_NAME=lol-crawler

# ── Dev ────────────────────────────────────────────────────────────────────
# Enable uvicorn hot-reload for the UI service (watches /svc/src for changes).
HOT_RELOAD=true

# ── Riot API ─────────────────────────────────────────────────────────────────
# Your Riot Games API key. Get one at https://developer.riotgames.com
# Development keys expire every 24h; production keys are permanent.
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Redis ─────────────────────────────────────────────────────────────────────
# Connection string for Redis. In dev this points at the local Docker container.
# In prod, point at a managed instance (Redis Cloud, ElastiCache, etc.).
REDIS_URL=redis://redis:6379/0

# Redis password.  Leave empty (no-auth) for dev.  Required when using
# docker-compose.prod.yml (which sets --requirepass).
# IMPORTANT: Services connect via REDIS_URL, not REDIS_PASSWORD.
# When enabling auth, also embed the password in REDIS_URL:
#   REDIS_URL=redis://:yourpassword@redis:6379/0
REDIS_PASSWORD=

# Host directory where Redis persists its RDB/AOF files.
# Change this to an absolute path to store data outside the project folder.
REDIS_DATA_DIR=./redis-data

# ── Storage ──────────────────────────────────────────────────────────────────
# Where raw match JSON is backed up to disk (write-through cache).
# Both fetcher (write) and parser (read) containers mount this path.
# On a Redis reset, parser auto-repopulates from disk — no data loss.
# Leave empty to disable disk persistence (data lives in Redis only).
MATCH_DATA_DIR=/pipeline-data/riot-api

# Raw match blob backend: "redis" (default) or "s3" (stub, not yet implemented).
RAW_STORE_BACKEND=redis
# S3 URL — only used when RAW_STORE_BACKEND=s3.
RAW_STORE_URL=

# ── Source waterfall ──────────────────────────────────────────────────────────
# Comma-separated source priority for the Fetcher waterfall.
# "riot" = Riot only. Add "opgg" to enable op.gg (e.g. "riot,opgg").
SOURCE_WATERFALL_ORDER=riot,opgg
# Raw source blob cache directory. Empty to disable disk persistence.
BLOB_DATA_DIR=./blob-data

# ── Pipeline tuning ───────────────────────────────────────────────────────────
# Minutes before the same player can be re-seeded (uses MAX of seeded_at / last_crawled_at).
SEED_COOLDOWN_MINUTES=30

# Seconds an unACKed stream message stays in the consumer's PEL before it can
# be reclaimed. Shorter = faster crash recovery; longer = more tolerance for slow jobs.
STREAM_ACK_TIMEOUT=60

# Max delivery attempts for a stream message before it is sent to stream:dlq.
MAX_ATTEMPTS=5

# Max recovery attempts in the DLQ before a message is archived to stream:dlq:archive.
DLQ_MAX_ATTEMPTS=3

# How often the Delay Scheduler polls delayed:messages (milliseconds).
DELAY_SCHEDULER_INTERVAL_MS=500
# Number of delayed messages processed per scheduler tick.
DELAY_SCHEDULER_BATCH_SIZE=100
# Max failures for a single delayed message before it is dropped.
DELAY_SCHEDULER_MAX_MEMBER_FAILURES=10
# Seconds the circuit breaker stays open after too many consecutive failures.
DELAY_SCHEDULER_CIRCUIT_OPEN_TTL_S=300
# Safety-net TTL (seconds) for delayed:envelope:{id} hashes (IMP-066).
DELAY_ENVELOPE_TTL_SECONDS=86400
# Backpressure ratio: defer dispatch when stream depth >= MAXLEN * ratio (IMP-067).
DELAY_SCHEDULER_BACKPRESSURE_RATIO=0.8

# TTL (seconds) for the per-player distributed lock held by the Analyzer.
# Should be longer than the time to process the largest possible match history.
ANALYZER_LOCK_TTL_SECONDS=300

# Per-second Riot API request cap (shared across all Fetcher + Crawler workers via Redis).
# Riot's limit: 20 req/s and 100 req/2 min. Do not exceed 20.
API_RATE_LIMIT_PER_SECOND=20

# ── Recovery service ────────────────────────────────────────────────────────
# Milliseconds an unACKed message must be idle before Recovery can reclaim it.
RECOVERY_CLAIM_IDLE_MS=60000
# Backoff ladder (ms) for retried DLQ messages. JSON list; each retry uses the next value.
RECOVERY_BACKOFF_MS=[5000,15000,60000,300000]
# Seconds Recovery sleeps between polls when system:halted=1.
RECOVERY_HALT_SLEEP_S=5.0
# Max entries in stream:dlq:archive before oldest entries are trimmed.
RECOVERY_ARCHIVE_MAXLEN=50000
# Number of DLQ entries read per consume call.
RECOVERY_COUNT=10
# Milliseconds to block waiting for new DLQ entries.
RECOVERY_BLOCK_MS=5000

# ── Discovery service ─────────────────────────────────────────────────────────
# How often the Discovery service polls for an idle pipeline (milliseconds).
DISCOVERY_POLL_INTERVAL_MS=5000

# Max co-players promoted to stream:puuid per idle poll cycle.
# Higher = faster fan-out; lower = more headroom for user-triggered seeds.
DISCOVERY_BATCH_SIZE=10
# Days of inactivity before a player is considered idle and re-queued by Discovery.
DISCOVERY_IDLE_CUTOFF_DAYS=3
# Promote 1 player when stream:puuid < threshold, even if not fully idle. 0 = disabled.
DISCOVERY_TRICKLE_THRESHOLD=2
# Default Riot region used when no region is specified in a payload.
DEFAULT_REGION=na1

# ── Rate limiter service ──────────────────────────────────────────────────────
# URL of the centralized rate-limiter HTTP service (lol-pipeline-rate-limiter).
# Default points to the Docker Compose service name on port 8079.
RATE_LIMITER_URL=http://rate-limiter:8079

# ── Domain registry (RATE-DYN-2) ──────────────────────────────────────────────
# Each domain is configured via DOMAIN_{PREFIX}_{PROPERTY} env vars.
# PREFIX = domain name uppercased, with ':' replaced by '_'.
# Properties: SHORT_LIMIT, LONG_LIMIT, SHORT_WINDOW_MS (default 1000),
#             LONG_WINDOW_MS (default 120000), HEADER_AWARE (default false),
#             HAS_METHOD_LIMITS (default false), UI_PCT (default 0.0)
#
# Use DOMAIN_{PREFIX}_NAME to override the derived domain name when
# the simple lowercase+colon transform is ambiguous.

# Riot Americas (na1/br1/la1/la2) — header_aware learns limits from API headers.
# Dev key hard limits: 20/1s, 100/120s. Stay at 18/90 (~10% headroom).
# Set HEADER_AWARE=true so the service self-tunes after each successful response.
DOMAIN_RIOT_AMERICAS_SHORT_LIMIT=18
DOMAIN_RIOT_AMERICAS_LONG_LIMIT=90
DOMAIN_RIOT_AMERICAS_HEADER_AWARE=true
DOMAIN_RIOT_AMERICAS_HAS_METHOD_LIMITS=true
DOMAIN_RIOT_AMERICAS_UI_PCT=0.0

# Other Riot regions (add as needed):
# DOMAIN_RIOT_EUROPE_SHORT_LIMIT=18
# DOMAIN_RIOT_EUROPE_LONG_LIMIT=90
# DOMAIN_RIOT_EUROPE_HEADER_AWARE=true
# DOMAIN_RIOT_EUROPE_HAS_METHOD_LIMITS=true
# DOMAIN_RIOT_EUROPE_UI_PCT=0.0

# OP.GG — static limits, 20% UI headroom (48 of 240 long slots reserved for UI).
# Pipeline gets 192 long slots; UI gets 48. Short window: 2/s (no split).
DOMAIN_OPGG_SHORT_LIMIT=2
DOMAIN_OPGG_LONG_LIMIT=240
DOMAIN_OPGG_HEADER_AWARE=false
DOMAIN_OPGG_HAS_METHOD_LIMITS=false
DOMAIN_OPGG_UI_PCT=0.20

# ── Redis connection tuning ──────────────────────────────────────────────────
# Socket timeout (seconds) for Redis read/write operations.
# Increase if Redis is on a high-latency link (e.g. cross-region managed Redis).
REDIS_SOCKET_TIMEOUT=30
# Connection timeout (seconds) for initial Redis TCP handshake.
REDIS_CONNECT_TIMEOUT=10

# ── Pipeline capacity ───────────────────────────────────────────────────────
# TTL (seconds) for parsed match data in Redis (match:{id}, participant:{id}:{puuid}).
# Default 7 days. Increase for deeper historical analysis; decrease to save memory.
MATCH_DATA_TTL_SECONDS=604800
# TTL (seconds) for raw match blobs in Redis (raw:match:{id}).  Default 24h.
# Set to match MATCH_DATA_TTL_SECONDS (604800) in production so replay-parse
# still finds raw blobs within the parsed-data retention window.
RAW_STORE_TTL_SECONDS=86400
# Maximum size of the players:all sorted set (caps total tracked players).
PLAYERS_ALL_MAX=50000
# Maximum entries in the discover:players sorted set. Caps fan-out growth.
# At 50K players with 10 matches each, this prevents the set from growing to ~500K members.
MAX_DISCOVER_PLAYERS=50000
# Maximum match IDs kept per player in player:matches:{puuid} sorted set.
# Older matches are trimmed after each parse. Increase for deeper match history.
PLAYER_MATCHES_MAX=500
# Max times run_consumer retries a crashing handler for the same message
# before sending it to the DLQ. Prevents poison-message infinite loops.
MAX_HANDLER_RETRIES=3
# Max times a consumer nacks a message before it is escalated to the DLQ.
MAX_NACK_ATTEMPTS=3
# TTL (seconds) for per-message retry tracking keys. Default 7 days.
RETRY_KEY_TTL=604800
# Maximum messages in any pipeline stream before Discovery considers it backlogged
# and pauses promoting new players (prevents flooding an already-full stream:match_id).
# Discovery reads this; the Crawler does not.
MAX_STREAM_BACKLOG=8000

# TTL (seconds) for champion aggregate stats keys (champion:stats:*, champion:index:*,
# champion:bans:*, matchup:*, patch:list). Default 90 days.
CHAMPION_STATS_TTL_SECONDS=7776000
# TTL (seconds) for player profile data (player:{puuid} hash). Default 30 days.
PLAYER_DATA_TTL_SECONDS=2592000
# TTL (seconds) for per-player priority keys. Default 24h.
PRIORITY_KEY_TTL_SECONDS=86400

# ── Champion Analytics ────────────────────────────────────────────────────────
# Fetch rank data (summoner + league) after each crawl. Increases API usage.
FETCH_RANK_ON_CRAWL=true
# Fetch match timeline data (build order, skill order). Doubles API usage per match.
FETCH_TIMELINE=true
# Track champion-vs-champion matchup stats from ranked solo queue.
TRACK_MATCHUPS=true
# Track champion ban stats from ranked solo queue.
TRACK_BANS=true

# ── Crawler Tuning ───────────────────────────────────────────────────────────
# TTL (seconds) for the seen:matches dedup set. Default 7 days.
SEEN_MATCHES_TTL_SECONDS=604800
# Crawler pauses publishing when stream:match_id exceeds this depth.
MATCH_ID_BACKPRESSURE_THRESHOLD=5000
# Weight for activity-rate in dynamic recrawl cooldown (higher = longer cooldown for active players).
ACTIVITY_RATE_WEIGHT=1.0
# Number of match IDs fetched per Riot API page request.
CRAWLER_PAGE_SIZE=100
# TTL (seconds) for cached rank data per player. Default 24h.
CRAWLER_RANK_TTL=86400
# TTL (seconds) for the per-player crawl cursor. Default 10 min.
CRAWLER_CURSOR_TTL=600
# Max rank history entries kept per player.
CRAWLER_RANK_HISTORY_MAX=500
# Recrawl cooldown tiers: high-activity players (≥RATE matches/day) wait HIGH_HOURS.
CRAWLER_COOLDOWN_HIGH_RATE=5
CRAWLER_COOLDOWN_HIGH_HOURS=2
# Mid-activity players (≥MID_RATE) wait MID_HOURS.
CRAWLER_COOLDOWN_MID_RATE=1
CRAWLER_COOLDOWN_MID_HOURS=6
# Low-activity players wait LOW_HOURS.
CRAWLER_COOLDOWN_LOW_HOURS=24

# ── Stats Lookback Window ────────────────────────────────────────────────────
# Unix timestamp (ms) marking the start of the current ranked split.
# Stats are recomputed from this point when the window advances past the cursor.
# Set to 0 to disable split-based filtering (default).
STATS_SPLIT_START_MS=0
# Minimum number of recent games to include regardless of split filter.
# If a player has more games than this, only the newest N are considered.
STATS_MIN_GAMES_LOOKBACK=100

# ── Logging ──────────────────────────────────────────────────────────────────
# Log level for all services. Valid values: DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO
# Log level for the waterfall coordinator logger (fetcher source-selection).
WATERFALL_LOG_LEVEL=INFO
# Directory for rotating log files. Leave empty to log only to stdout (default).
# When set, each service writes to {LOG_DIR}/{service_name}.log (150MB max, 3 backups).
# LOG_DIR=

# ── op.gg Integration (optional) ─────────────────────────────────────────────
# Requests per second to op.gg (unauthenticated; conservative default).
OPGG_RATE_LIMIT_PER_SECOND=2
# Requests per 2-minute window (analogous to Riot long window).
OPGG_RATE_LIMIT_LONG=240
# Directory to store raw op.gg match data (leave empty to disable disk storage).
OPGG_MATCH_DATA_DIR=/pipeline-data/opgg
# TTL (seconds) for the Redis-cached op.gg summoner ID (PUUID -> summoner_id).
OPGG_SUMMONER_CACHE_TTL_SECONDS=3600
# Number of recent games fetched per op.gg on-demand waterfall request.
OPGG_FETCH_GAME_LIMIT=5
# Number of games pre-fetched to BlobStore on UI player search.
OPGG_PREFETCH_LIMIT=20


# ── Admin UI ─────────────────────────────────────────────────────────────────
# Secret required for all write operations on the Admin UI service (port 8081).
# Set to a strong random value in production. Leave empty to disable auth (dev only).
ADMIN_UI_SECRET=change-me-in-production

# ── UI / DDragon ─────────────────────────────────────────────────────────────
# HTTP port the read-only UI service listens on inside the container.
UI_PORT=8080
# Timeout (seconds) for DDragon asset fetches.
DDRAGON_TIMEOUT_S=5.0
# TTL (seconds) for per-player stats fragment cache. Default 6 hours.
STATS_FRAGMENT_CACHE_TTL_S=21600

# ── GitHub (optional, for CI) ─────────────────────────────────────────────────
# GITHUB_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Hugging Face ──────────────────────────────────────────────────────────────
# Hugging Face Datasets repo for seed data (download/upload).
# Private dataset — HUGGINGFACE_TOKEN required for both download and upload.
HF_DATASET_REPO=CityPopper/LoL-Scraper

# API token for uploading anonymized seed data to Hugging Face Datasets.
# Get yours at https://huggingface.co/settings/tokens (write access required for uploads).
HUGGINGFACE_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
