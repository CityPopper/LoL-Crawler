# ── Security ──────────────────────────────────────────────────────────────────
# IMPORTANT: In production, restrict this file's permissions:
#   chmod 600 .env
#   chown <service-user>:<service-group> .env
# This prevents other users on the host from reading secrets (RIOT_API_KEY,
# REDIS_PASSWORD) stored in this file.

# ── Container runtime ─────────────────────────────────────────────────────────
# Default runtime is podman. Override per-command: RUNTIME=docker just build
# Or set here to always use docker:
# RUNTIME=docker

# Compose project name — controls the Docker/Podman network name used by
# `just seed` and `just admin` (default: directory name).
# COMPOSE_PROJECT_NAME=lol-crawler

# ── Dev ────────────────────────────────────────────────────────────────────
# Enable uvicorn hot-reload for the UI service (watches /svc/src for changes).
HOT_RELOAD=false

# ── Riot API ─────────────────────────────────────────────────────────────────
# Your Riot Games API key. Get one at https://developer.riotgames.com
# Development keys expire every 24h; production keys are permanent.
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Redis ─────────────────────────────────────────────────────────────────────
# Connection string for Redis. In dev this points at the local Docker container.
# In prod, point at a managed instance (Redis Cloud, ElastiCache, etc.).
REDIS_URL=redis://redis:6379/0

# Redis password.  Leave empty (no-auth) for dev.  Required when using
# docker-compose.prod.yml (which sets --requirepass).
# IMPORTANT: Services connect via REDIS_URL, not REDIS_PASSWORD.
# When enabling auth, also embed the password in REDIS_URL:
#   REDIS_URL=redis://:yourpassword@redis:6379/0
REDIS_PASSWORD=

# Host directory where Redis persists its RDB/AOF files.
# Change this to an absolute path to store data outside the project folder.
REDIS_DATA_DIR=./redis-data

# ── Storage ──────────────────────────────────────────────────────────────────
# Where raw match JSON is backed up to disk (write-through cache).
# Both fetcher (write) and parser (read) containers mount this path.
# On a Redis reset, parser auto-repopulates from disk — no data loss.
# Leave empty to disable disk persistence (data lives in Redis only).
MATCH_DATA_DIR=/match-data

# Raw match blob backend: "redis" (default) or "s3" (stub, not yet implemented).
RAW_STORE_BACKEND=redis
# S3 URL — only used when RAW_STORE_BACKEND=s3.
RAW_STORE_URL=

# ── Pipeline tuning ───────────────────────────────────────────────────────────
# Minutes before the same player can be re-seeded (uses MAX of seeded_at / last_crawled_at).
SEED_COOLDOWN_MINUTES=30

# Seconds an unACKed stream message stays in the consumer's PEL before it can
# be reclaimed. Shorter = faster crash recovery; longer = more tolerance for slow jobs.
STREAM_ACK_TIMEOUT=60

# Max delivery attempts for a stream message before it is sent to stream:dlq.
MAX_ATTEMPTS=5

# Max recovery attempts in the DLQ before a message is archived to stream:dlq:archive.
DLQ_MAX_ATTEMPTS=3

# How often the Delay Scheduler polls delayed:messages (milliseconds).
DELAY_SCHEDULER_INTERVAL_MS=500

# TTL (seconds) for the per-player distributed lock held by the Analyzer.
# Should be longer than the time to process the largest possible match history.
ANALYZER_LOCK_TTL_SECONDS=300

# Per-second Riot API request cap (shared across all Fetcher + Crawler workers via Redis).
# Riot's limit: 20 req/s and 100 req/2 min. Do not exceed 20.
API_RATE_LIMIT_PER_SECOND=20

# ── Discovery service ─────────────────────────────────────────────────────────
# How often the Discovery service polls for an idle pipeline (milliseconds).
DISCOVERY_POLL_INTERVAL_MS=5000

# Max co-players promoted to stream:puuid per idle poll cycle.
# Higher = faster fan-out; lower = more headroom for user-triggered seeds.
DISCOVERY_BATCH_SIZE=10

# ── Rate limiter (production tuning) ──────────────────────────────────────────
# Window sizes for the sliding window rate limiter.
# Dev keys: short=1s, long=120s (20 req/1s, 100 req/2min)
# Prod keys: short=10s, long=600s (500 req/10s, 30000 req/10min)
# Change these when switching from a dev API key to a production key.
RATE_LIMIT_SHORT_WINDOW_S=1
RATE_LIMIT_LONG_WINDOW_S=120

# ── Redis connection tuning ──────────────────────────────────────────────────
# Socket timeout (seconds) for Redis read/write operations.
# Increase if Redis is on a high-latency link (e.g. cross-region managed Redis).
REDIS_SOCKET_TIMEOUT=30
# Connection timeout (seconds) for initial Redis TCP handshake.
REDIS_CONNECT_TIMEOUT=10

# ── Pipeline capacity ───────────────────────────────────────────────────────
# TTL (seconds) for parsed match data in Redis (match:{id}, participant:{id}:{puuid}).
# Default 7 days. Increase for deeper historical analysis; decrease to save memory.
MATCH_DATA_TTL_SECONDS=604800
# TTL (seconds) for raw match blobs in Redis (raw:match:{id}).  Default 24h.
# Set to match MATCH_DATA_TTL_SECONDS (604800) in production so replay-parse
# still finds raw blobs within the parsed-data retention window.
RAW_STORE_TTL_SECONDS=86400
# Maximum size of the players:all sorted set (caps total tracked players).
PLAYERS_ALL_MAX=50000
# Maximum entries in the discover:players sorted set. Caps fan-out growth.
# At 50K players with 10 matches each, this prevents the set from growing to ~500K members.
MAX_DISCOVER_PLAYERS=50000
# Maximum match IDs kept per player in player:matches:{puuid} sorted set.
# Older matches are trimmed after each parse. Increase for deeper match history.
PLAYER_MATCHES_MAX=500
# TTL (seconds) for player:priority:{puuid} keys. If a seeded player's pipeline
# stalls, the priority key auto-expires so Discovery is not blocked forever.
# Default 24 hours.
PRIORITY_KEY_TTL=86400
# Max times run_consumer retries a crashing handler for the same message
# before sending it to the DLQ. Prevents poison-message infinite loops.
MAX_HANDLER_RETRIES=3
# Maximum messages in any pipeline stream before Discovery considers it backlogged
# and pauses promoting new players (prevents flooding an already-full stream:match_id).
# Discovery reads this; the Crawler does not.
MAX_STREAM_BACKLOG=8000

# TTL (seconds) for champion aggregate stats keys (champion:stats:*, champion:index:*,
# champion:bans:*, matchup:*, patch:list). Default 90 days.
CHAMPION_STATS_TTL_SECONDS=7776000

# ── Champion Analytics ────────────────────────────────────────────────────────
# Fetch rank data (summoner + league) after each crawl. Increases API usage.
FETCH_RANK_ON_CRAWL=true
# Fetch match timeline data (build order, skill order). Doubles API usage per match.
FETCH_TIMELINE=false
# Track champion-vs-champion matchup stats from ranked solo queue.
TRACK_MATCHUPS=true
# Track champion ban stats from ranked solo queue.
TRACK_BANS=true

# ── Crawler Tuning ───────────────────────────────────────────────────────────
# TTL (seconds) for the seen:matches dedup set. Default 7 days.
SEEN_MATCHES_TTL_SECONDS=604800
# Crawler pauses publishing when stream:match_id exceeds this depth.
MATCH_ID_BACKPRESSURE_THRESHOLD=5000
# Weight for activity-rate in dynamic recrawl cooldown (higher = longer cooldown for active players).
ACTIVITY_RATE_WEIGHT=1.0

# ── Logging ──────────────────────────────────────────────────────────────────
# Log level for all services. Valid values: DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO
# Directory for rotating log files. Leave empty to log only to stdout (default).
# When set, each service writes to {LOG_DIR}/{service_name}.log (150MB max, 3 backups).
# LOG_DIR=

# ── GitHub (optional, for CI) ─────────────────────────────────────────────────
# GITHUB_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
